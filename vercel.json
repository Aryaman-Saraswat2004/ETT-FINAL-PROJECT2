{
    "version": 2,
    "build": {
        "env": {
            "REACT_APP_API_URL": "/api"
        }
    },
    "buildCommand": "cd client && npm install && npm run build",
    "outputDirectory": "client/build",
    "rewrites": [
        {
            "source": "/api/(.*)",
            "destination": "/api"
        },
        {
            "source": "/((?!api).*)",
            "destination": "/index.html"
        }
    ]
}